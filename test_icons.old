package main

import (
	"fyne.io/fyne/v2"
	"fyne.io/fyne/v2/app"
	"fyne.io/fyne/v2/container"
	"fyne.io/fyne/v2/theme"
	"fyne.io/fyne/v2/widget"
)

func main() {
	myApp := app.New()
	myWindow := myApp.NewWindow("Test Icons")

	// Используем существующие иконки
	content := container.NewVBox(
		widget.NewButtonWithIcon("Кнопка", theme.ConfirmIcon(), func() {}),
		widget.NewButtonWithIcon("", theme.MediaRecordIcon(), func() {}),
		widget.NewIcon(theme.MediaPlayIcon()),
		widget.NewLabel("Доступные иконки:"),
	)

	myWindow.SetContent(content)
	myWindow.Resize(fyne.NewSize(300, 400))
	myWindow.ShowAndRun()
}
